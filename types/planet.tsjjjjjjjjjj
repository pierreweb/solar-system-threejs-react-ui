//types/planet.ts
export interface PlanetInfo {
  id: string;
  name: string;
  type: string;
  satelliteCount: string;
  mass: string;
  equatorialRadius: string;
  density: string;
  volume: string;
  orbitalPeriod: string;
  rotationPeriod: string;
  distanceFromSun: string;
  shortDescription: string;
}
